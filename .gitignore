# .gitignore - cngsmOS VSCode Extension
# ─────────────────────────────────────
# SECURITY: Prevents committing secrets, build artifacts,
# and sensitive files to version control.

# Dependencies
node_modules/

# Build output
dist/
out/

# Environment variables & secrets (NEVER commit these)
.env
.env.*
*.env
secrets.*
**/*.key
**/*.pem
**/*.cert

# VS Code extension package
*.vsix

# macOS
.DS_Store

# Windows
Thumbs.db

# Logs
*.log
npm-debug.log*

# Snapshots (large debug dumps)
Snapshots/

# Python cache
__pycache__/
*.pyc
